      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "kakao",
    "kakaotalk",
    "loco",
    "protocol"
  ],
  "license": "MIT",

  "dependencies": {
    "bson": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "assets"
  ],
  "publishConfig": {
    "access": "public"
  }

}